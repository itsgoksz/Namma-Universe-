# Aiva — Environment Variables
# Copy this file to .env and fill in the values

# Application
DEBUG=true
SECRET_KEY=change-me-in-production-generate-a-random-key

# Database
DATABASE_URL=postgresql+asyncpg://aiva:aiva@localhost:5432/aiva

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Voice Provider ("vapi" or "retell")
VOICE_PROVIDER=vapi
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=
RETELL_API_KEY=

# Twilio (SMS + WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# SendGrid (Email)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@aiva.ai

# Default timezone
DEFAULT_TIMEZONE=America/New_York
